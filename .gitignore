<edit_description>
Add a .gitignore file for a Go project.
</edit_description>

```
# Binaries for programs and plugins
*.exe
*.dll
*.so
*.dylib

# Test binary
*.test

# Output of the go coverage tool
*.out

# Dependency directories (vendor/)
vendor/

# Go workspace file
go.work

# IDE/editor specific files
.vscode/
.idea/
*.iml

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
*.swp

# Build artifacts
bin/
build/

# Go modules
go.sum
